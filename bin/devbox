#!/usr/bin/env bash
# devbox — optional WSL helpers (doctor, repo entry). Not required for pnpm dev in ~/code.
set -euo pipefail

die() { printf 'devbox: %s\n' "$*" >&2; exit 1; }
warn() { printf 'devbox warning: %s\n' "$*" >&2; }

_devbox_script_path() {
  local script="${BASH_SOURCE[0]}"
  if command -v readlink >/dev/null 2>&1; then
    readlink -f "$script" 2>/dev/null && return 0
  fi
  if command -v realpath >/dev/null 2>&1; then
    realpath "$script" 2>/dev/null && return 0
  fi
  printf '%s' "$script"
}

_devbox_script_root() {
  local script root
  script="$(_devbox_script_path)"
  root="$(cd "$(dirname "$script")/.." && pwd)"
  printf '%s' "$root"
}

resolve_devbox_root() {
  local default_root
  default_root="$(_devbox_script_root)"
  if [[ -n "${DEVBOX_ROOT:-}" && "${DEVBOX_ALLOW_OVERRIDE:-}" == "1" ]]; then
    printf '%s' "$DEVBOX_ROOT"
    return 0
  fi
  if [[ -n "${DEVBOX_ROOT:-}" && "$DEVBOX_ROOT" != "$default_root" ]]; then
    warn "ignoring DEVBOX_ROOT=$DEVBOX_ROOT; using $default_root"
  fi
  printf '%s' "$default_root"
}

resolve_code_dir() {
  local default_dir="$HOME/code"
  if [[ -n "${DEVBOX_CODE_DIR:-}" && "${DEVBOX_ALLOW_OVERRIDE:-}" == "1" ]]; then
    printf '%s' "$DEVBOX_CODE_DIR"
    return 0
  fi
  if [[ -n "${DEVBOX_CODE_DIR:-}" && "$DEVBOX_CODE_DIR" != "$default_dir" ]]; then
    die "DEVBOX_CODE_DIR override ignored (set DEVBOX_ALLOW_OVERRIDE=1 to allow)"
  fi
  printf '%s' "$default_dir"
}

DEVBOX_ROOT="$(resolve_devbox_root)"
CODE_DIR="$(resolve_code_dir)"
PROFILES_DIR="$DEVBOX_ROOT/profiles"

usage() {
  cat <<'EOF'
devbox — WSL2 machine bootstrap helper

Usage:
  devbox                     Interactive menu (TTY only)
  devbox setup               Guided wizard (TLS, toolchain, shell)
  devbox setup tls           Corporate CA / Zscaler only
  devbox setup git           Use Windows Git Credential Manager from WSL (HTTPS SSO)
  devbox setup docker        Docker Desktop CLI from WSL (docker compose)
  devbox setup hosts         Sync WSL /etc/hosts dev entries to Windows (browser)
  devbox setup -y            Wizard with defaults (non-interactive)
  devbox tls                 Alias for: devbox setup tls
  devbox reset [--full] [-y] Undo install.sh / setup (see devbox reset --help)
  devbox doctor              Verify Node, pnpm, paths, TLS, ownership
  devbox env [profile]       Print allowlisted environment variables
  devbox repo <name> [--trust-hooks]
                             Enter ~/code/<name> with profile env loaded
  devbox list                List repos under ~/code
  devbox help                Show this message

Profiles (optional):
  ~/devbox/profiles/<name>.env        (shared)
  ~/code/<repo>/.devbox/profile.env   (repo override)

Per-repo hooks (opt-in only):
  ~/code/<repo>/.devbox/hooks.sh
  Run only with --trust-hooks or DEVBOX_TRUST_HOOKS=1
EOF
}

activate_fnm() {
  export PATH="${HOME}/.local/share/fnm:${HOME}/.fnm:${PATH}"
  if command -v fnm >/dev/null 2>&1; then
    eval "$(fnm env --shell bash)"
  fi
}

validate_node_version() {
  local ver="${1:-}"
  [[ "$ver" =~ ^[0-9]+(\.[0-9]+)*(-[a-zA-Z0-9.]+)?$ ]] || die "invalid NODE_VERSION: $ver"
}

load_profile() {
  local name="$1"
  local f=""
  if [[ -f "$PROFILES_DIR/${name}.env" ]]; then
    f="$PROFILES_DIR/${name}.env"
  elif [[ -f "$PROFILES_DIR/default.env" ]]; then
    f="$PROFILES_DIR/default.env"
  fi
  if [[ -n "$f" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$f"
    set +a
  fi
}

load_repo_profile() {
  local repo_dir="$1"
  local f="$repo_dir/.devbox/profile.env"
  if [[ -f "$f" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$f"
    set +a
  fi
}

apply_node_version() {
  activate_fnm
  if [[ -n "${NODE_VERSION:-}" ]]; then
    validate_node_version "$NODE_VERSION"
    if command -v fnm >/dev/null 2>&1; then
      fnm use "$NODE_VERSION" 2>/dev/null || fnm install "$NODE_VERSION"
      fnm use "$NODE_VERSION"
    fi
  fi
}

validate_repo_name() {
  local name="$1"
  [[ -n "$name" ]] || die "repo name required"
  [[ "$name" != *"/"* && "$name" != *"\\"* ]] || die "repo name must not contain path separators"
  [[ "$name" != "." && "$name" != ".." ]] || die "invalid repo name"
  [[ "$name" != *".."* ]] || die "repo name must not contain '..'"
}

resolve_repo_dir() {
  local name="$1"
  validate_repo_name "$name"
  [[ -d "$CODE_DIR" ]] || die "workspace missing: $CODE_DIR"

  local code_real repo_dir
  if ! code_real="$(realpath -e "$CODE_DIR")"; then
    die "cannot resolve workspace: $CODE_DIR"
  fi
  if [[ ! -d "$CODE_DIR/$name" ]]; then
    die "repo not found: $CODE_DIR/$name (clone into ~/code first)"
  fi
  if ! repo_dir="$(realpath -e "$CODE_DIR/$name")"; then
    die "cannot resolve repo path: $CODE_DIR/$name"
  fi
  if [[ "$repo_dir" != "$code_real" && "$repo_dir" != "$code_real/"* ]]; then
    die "repo path escapes workspace (resolved: $repo_dir)"
  fi
  printf '%s' "$repo_dir"
}

path_owner() {
  local p="$1"
  if stat -c '%U' "$p" >/dev/null 2>&1; then
    stat -c '%U' "$p"
  else
    stat -f '%Su' "$p"
  fi
}

check_owned_by_user() {
  local p="$1" label="$2"
  [[ -e "$p" ]] || return 0
  local owner me
  owner="$(path_owner "$p")"
  me="$(whoami)"
  if [[ "$owner" != "$me" ]]; then
    warn "$label not owned by $me (owner: $owner): $p"
    return 1
  fi
  printf '  %s: ok (owned by %s)\n' "$label" "$me"
}

is_secret_env_key() {
  local key="$1"
  local upper
  upper="$(printf '%s' "$key" | tr '[:lower:]' '[:upper:]')"
  [[ "$upper" == *KEY* || "$upper" == *TOKEN* || "$upper" == *SECRET* \
    || "$upper" == *PASSWORD* || "$upper" == *CREDENTIAL* || "$upper" == *AUTH* ]]
}

is_allowed_env_key() {
  local key="$1"
  case "$key" in
    NODE_VERSION | ENV | API_URL | PNPM_HOME)
      return 0
      ;;
    DEVBOX_* | PNPM_*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

print_safe_env() {
  local key line
  while IFS= read -r line; do
    [[ "$line" == *"="* ]] || continue
    key="${line%%=*}"
    if is_secret_env_key "$key"; then
      printf '%s=<redacted>\n' "$key"
    elif is_allowed_env_key "$key"; then
      printf '%s\n' "$line"
    fi
  done < <(env | sort)
}

cmd_doctor() {
  echo "devbox doctor"
  echo "  DEVBOX_ROOT=$DEVBOX_ROOT"
  echo "  CODE_DIR=$CODE_DIR"
  if grep -qi microsoft /proc/version 2>/dev/null; then
    echo "  WSL: yes"
  else
    echo "  WSL: no (expected on Windows via WSL2 Ubuntu)"
  fi

  check_owned_by_user "$DEVBOX_ROOT" "DEVBOX_ROOT" || true
  check_owned_by_user "$DEVBOX_ROOT/bin/devbox" "devbox script" || true

  local cli="$HOME/.local/bin/devbox"
  if [[ -L "$cli" ]]; then
    local target expected
    target="$(readlink "$cli")"
    expected="$DEVBOX_ROOT/bin/devbox"
    if [[ "$target" == "$expected" ]]; then
      echo "  devbox symlink: ok -> $target"
    else
      warn "devbox symlink points to $target (expected $expected)"
    fi
    check_owned_by_user "$cli" "devbox CLI symlink" || true
  elif [[ -e "$cli" ]]; then
    warn "devbox exists but is not a symlink: $cli"
  else
    echo "  devbox symlink: missing ($cli) — run: bash install.sh"
  fi

  activate_fnm
  for cmd in node npm pnpm just git; do
    if command -v "$cmd" >/dev/null 2>&1; then
      echo "  $cmd: $($cmd --version 2>/dev/null | head -1)"
    else
      echo "  $cmd: MISSING — run: devbox setup"
    fi
  done
  if command -v pnpm >/dev/null 2>&1; then
    echo "  pnpm store: $(pnpm config get store-dir 2>/dev/null || echo unknown)"
  fi
  if [[ -d "$CODE_DIR" ]]; then
    echo "  workspace: ok ($CODE_DIR)"
  else
    echo "  workspace: missing — mkdir -p $CODE_DIR"
  fi
  if grep -qi microsoft /proc/version 2>/dev/null; then
    local gcm_status docker_status
    gcm_status="$(devbox_git_gcm_status 2>/dev/null || true)"
    if [[ "$gcm_status" == "ok" ]]; then
      echo "  git credential (Windows GCM): ok"
    else
      echo "  git credential (Windows GCM): $gcm_status"
      echo "  fix: devbox setup git  (install Git for Windows with GCM first)"
    fi
    docker_status="$(devbox_docker_status 2>/dev/null || true)"
    if [[ "$docker_status" == "ok" ]]; then
      echo "  docker (Docker Desktop): ok"
      echo "  docker compose: $(docker compose version 2>/dev/null | head -1)"
    else
      echo "  docker (Docker Desktop): $docker_status"
      echo "  fix: devbox setup docker  (see docs/DOCKER.md)"
    fi
  fi
  devbox_load_env_local
  if devbox_test_https; then
    echo "  HTTPS (nodejs.org): ok"
  else
    echo "  HTTPS (nodejs.org): FAILED — run: devbox setup tls"
    if [[ -n "${DEVBOX_CA_CERT_FILE:-}" ]]; then
      echo "  DEVBOX_CA_CERT_FILE=$DEVBOX_CA_CERT_FILE (try: devbox setup tls to apply)"
    fi
  fi
  local pwd_out
  pwd_out="$(pwd 2>/dev/null || true)"
  if [[ "$pwd_out" == /mnt/* ]]; then
    echo "  warning: current directory is on Windows mount ($pwd_out) — use ~/code for speed"
  fi
}

cmd_env() {
  local profile="${1:-default}"
  load_profile "$profile"
  apply_node_version
  echo "# profile: $profile (allowlisted keys only)"
  print_safe_env
}

cmd_list() {
  if [[ ! -d "$CODE_DIR" ]]; then
    echo "no workspace at $CODE_DIR"
    exit 0
  fi
  local d base
  for d in "$CODE_DIR"/*; do
    [[ -d "$d" ]] || continue
    base="$(basename "$d")"
    [[ "$base" == .* ]] && continue
    printf '%s\n' "$base"
  done
}

maybe_run_hooks() {
  local repo_dir="$1"
  local trust_hooks="$2"
  local hooks="$repo_dir/.devbox/hooks.sh"
  [[ -f "$hooks" ]] || return 0

  if [[ "$trust_hooks" == "1" || "${DEVBOX_TRUST_HOOKS:-}" == "1" ]]; then
    # shellcheck source=/dev/null
    source "$hooks"
    return 0
  fi

  warn ".devbox/hooks.sh exists but was not executed"
  warn "use: devbox repo $(basename "$repo_dir") --trust-hooks   or DEVBOX_TRUST_HOOKS=1"
}

cmd_repo() {
  local trust_hooks=0
  local name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --trust-hooks)
        trust_hooks=1
        shift
        ;;
      -h | --help)
        echo "usage: devbox repo <name> [--trust-hooks]"
        exit 0
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        [[ -z "$name" ]] || die "unexpected extra argument: $1"
        name="$1"
        shift
        ;;
    esac
  done
  [[ -n "$name" ]] || die "usage: devbox repo <name> [--trust-hooks]"

  local repo_dir
  repo_dir="$(resolve_repo_dir "$name")"

  load_profile "$name"
  load_repo_profile "$repo_dir"
  apply_node_version
  maybe_run_hooks "$repo_dir" "$trust_hooks"

  cd "$repo_dir"
  echo "devbox: $repo_dir"
  exec "${SHELL:-bash}" -l
}

cmd_reset() {
  exec bash "$DEVBOX_ROOT/scripts/reset-devbox.sh" "$@"
}

cmd_setup_git() {
  if devbox_configure_git_gcm; then
    echo "Git HTTPS will use Windows Git Credential Manager (browser SSO)."
    echo "Test: cd ~/code && git clone https://github.com/<org>/<repo>.git"
    echo "If no browser opens, clear stale creds in Windows Credential Manager and retry."
  else
    die "could not configure Git GCM — install Git for Windows (GCM), then re-run"
  fi
}

cmd_setup_hosts() {
  bash "$DEVBOX_ROOT/scripts/sync-hosts-to-windows.sh"
}

cmd_setup_docker() {
  if devbox_configure_docker; then
    echo "Docker CLI in WSL uses Docker Desktop (WSL integration)."
    echo "Test: docker run --rm hello-world"
    echo "In your repo: docker compose up -d"
  else
    echo ""
    echo "If integration is already ON, toggle it off and on for $(devbox_wsl_distro_name 2>/dev/null || echo 'your distro'),"
    echo "Apply & Restart, then: wsl --shutdown  (PowerShell)  and re-open Ubuntu."
    die "docker not ready — see docs/DOCKER.md"
  fi
}

cmd_setup() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -y | --yes)
        DEVBOX_SETUP_NONINTERACTIVE=1
        shift
        ;;
      tls)
        devbox_setup_tls_interactive
        return 0
        ;;
      git)
        cmd_setup_git
        return 0
        ;;
      docker)
        cmd_setup_docker
        return 0
        ;;
      hosts)
        cmd_setup_hosts
        return 0
        ;;
      -h | --help)
        echo "usage: devbox setup [-y] [tls|git|docker|hosts]"
        return 0
        ;;
      *)
        die "unknown setup option: $1 (try: devbox setup tls | git | docker | hosts)"
        ;;
    esac
  done
  devbox_setup_wizard
}

# shellcheck source=../scripts/lib/corporate-ca.sh
source "$DEVBOX_ROOT/scripts/lib/corporate-ca.sh"
# shellcheck source=../scripts/lib/git-gcm.sh
source "$DEVBOX_ROOT/scripts/lib/git-gcm.sh"
# shellcheck source=../scripts/lib/docker-desktop.sh
source "$DEVBOX_ROOT/scripts/lib/docker-desktop.sh"
# shellcheck source=../scripts/lib/interactive.sh
source "$DEVBOX_ROOT/scripts/lib/interactive.sh"

main() {
  local cmd="${1-}"

  if [[ -z "$cmd" ]]; then
    if devbox_is_tty; then
      devbox_interactive_menu
    else
      usage
    fi
    return 0
  fi

  shift
  case "$cmd" in
    setup) cmd_setup "$@" ;;
    reset) cmd_reset "$@" ;;
    tls) devbox_setup_tls_interactive ;;
    doctor) cmd_doctor ;;
    env) cmd_env "${1:-default}" ;;
    repo) cmd_repo "$@" ;;
    list) cmd_list ;;
    help | -h | --help) usage ;;
    *)
      usage
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
