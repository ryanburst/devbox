# Machine-specific settings (copy to env.local — never commit env.local).
# Sourced at the start of install.sh. Use chmod 600 config/env.local
#
# New developers: see docs/ONBOARDING.md and docs/CORPORATE-TLS.md

# --- Corporate TLS (configure BEFORE bash install.sh if curl fails HTTPS) ---
# export DEVBOX_CA_CERT_FILE=$HOME/devbox/config/zscaler-root.cer
#
# Zscaler + WSL/Windows interop (one-time machine setup):
#   bash scripts/sync-zscaler-ca.sh

# --- HTTP proxy (if required) ---
# export HTTP_PROXY=http://proxy.company.com:8080
# export HTTPS_PROXY=http://proxy.company.com:8080
# export NO_PROXY=localhost,127.0.0.1,.company.com

# --- Shell / devbox CLI (optional) ---
# export DEVBOX_PATCH_SHELL=1
# export DEVBOX_ALLOW_OVERRIDE=1
# export DEVBOX_TRUST_HOOKS=1

# --- Paths / versions (defaults in config/versions.sh) ---
# export DEVBOX_NODE_VERSION=22
# export DEVBOX_PNPM_STORE=$HOME/.pnpm-store
# export DEVBOX_CODE_DIR=$HOME/code
