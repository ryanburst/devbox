# Copy to env.local and uncomment as needed for corporate networks.
# install.sh sources config/env.local when present (chmod 600 recommended).

# export HTTP_PROXY=http://proxy.company.com:8080
# export HTTPS_PROXY=http://proxy.company.com:8080
# export NO_PROXY=localhost,127.0.0.1,.company.com

# Corporate TLS inspection — prefer installing your org CA (do NOT disable strict-ssl):
# export DEVBOX_CA_CERT_FILE=/path/to/company-root-ca.pem

# Auto-append devbox block to ~/.bashrc (off by default for change control)
# export DEVBOX_PATCH_SHELL=1

# Allow DEVBOX_ROOT / DEVBOX_CODE_DIR overrides (off by default)
# export DEVBOX_ALLOW_OVERRIDE=1

# Run .devbox/hooks.sh without passing --trust-hooks
# export DEVBOX_TRUST_HOOKS=1

# Override pinned versions (defaults in config/versions.sh)
# export DEVBOX_NODE_VERSION=22
# export DEVBOX_PNPM_STORE=$HOME/.pnpm-store
# export DEVBOX_CODE_DIR=$HOME/code
